# Meme projet que dans le dashboard Supabase ou tu configures Auth et les modeles d e-mail.
# Project Settings → API : Project URL et anon public.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optionnel : sous-domaine du projet (dans l URL https://CECI.supabase.co).
# Si defini, l app refuse de demarrer si VITE_SUPABASE_URL pointe vers un autre projet.
# VITE_SUPABASE_EXPECTED_REF=

VITE_APP_ENV=development
